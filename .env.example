# Max upload size in bytes (default: 500 MiB = 524288000). UI and API use the same value.
# MAX_FILE_SIZE_BYTES=524288000

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=

# 32-byte AES-256 key (64 hex chars). Keep secret; do not commit.
ENCRYPTION_KEY=
# Optional: separate secret for upload finalize tokens (min 32 chars).
# UPLOAD_FINALIZE_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Feedback (bug reports to Discord; server-side, not a public link)
DISCORD_WEBHOOK_URL=

# Rate limiting and proxy trust
# RATE_WINDOW_MS=120000
# RATE_MAX_POINTS=200
# RATE_LIMIT_DISABLED=0
# TRUST_PROXY_HEADERS=0

# Cron auth safety
# CRON_SECRET=
# ALLOW_INSECURE_LOCAL_CRON=0
